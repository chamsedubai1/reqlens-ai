# PostgreSQL (added in Plan 2). Self-hosted Postgres connection string.
# Example: postgres://user:password@localhost:5432/reqlens
DATABASE_URL=

# Auth session signing secret (added in Plan 2). Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=

# AI reviewer. Any OpenAI-compatible chat-completions endpoint works (OpenAI, or
# a self-hosted open model like Qwen via Ollama / vLLM / DashScope).
# When NOTHING below is set, the app uses the deterministic keyless mock reviewer.
#
# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# --- Option B: self-hosted Qwen (OpenAI-compatible) ---
# Ollama:  AI_BASE_URL=http://localhost:11434/v1   AI_MODEL=qwen2.5:14b   (AI_API_KEY optional)
# vLLM:    AI_BASE_URL=http://localhost:8000/v1     AI_MODEL=Qwen/Qwen2.5-14B-Instruct   AI_API_KEY=<if configured>
# DashScope: AI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  AI_MODEL=qwen-plus  AI_API_KEY=sk-...
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
